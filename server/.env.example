# Copy this file to .env for local overrides, or set these as environment
# variables directly in your hosting platform's dashboard (e.g. Render).

PORT=4000

# A long, random, secret string used to sign login tokens. MUST be changed
# for any real/production deployment.
JWT_SECRET=change-this-to-a-long-random-secret

# Comma-separated list of frontend origins allowed to call this API.
# Example: https://civicconnect.onrender.com
ALLOWED_ORIGINS=
